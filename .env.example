# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1  # Optional: Custom OpenAI-compatible endpoint

# Grok (xAI)
GROK_API_KEY=your_grok_api_key_here
GROK_BASE_URL=https://api.x.ai/v1  # Optional: Custom endpoint

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com  # Optional: Custom endpoint

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=ebook-library
PINECONE_SEO_INDEX_NAME=seo-articles

# Perplexity AI
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_BASE_URL=https://api.perplexity.ai  # Optional: Custom endpoint

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1  # Optional: Custom endpoint

# Custom OpenAI-Compatible API (e.g., LM Studio, Ollama, vLLM)
CUSTOM_API_KEY=your_custom_api_key_here
CUSTOM_BASE_URL=http://localhost:1234/v1  # Your custom API endpoint
CUSTOM_MODEL=your_model_name  # Model name to use

# Tavily (for SERP analysis)
TAVILY_API_KEY=your_tavily_api_key_here

# Default LLM provider (openai, grok, gemini, deepseek, perplexity, openrouter, custom)
DEFAULT_LLM_PROVIDER=openai

# Redis (optional) — response cache for repeated /api/deliberate calls (same query + model + attachment hash)
# REDIS_URL=redis://localhost:6379
